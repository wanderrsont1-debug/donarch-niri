(defpoll active_ws
  :interval "200ms"
  `hyprctl activeworkspace -j | jq '.id'`)

(defwindow minimap
  :monitor 0
  :stacking "overlay"
  
  (minimap)
)

(defwidget minimap []
  (box :orientation "vertical" :class "grid" :space-evenly true
  
    (box :orientation "horizontal"
      (button
        :class "${active_ws == 1 ? "active" : "inactive"}"
        "1")
      (button
        :class "${active_ws == 2 ? "active" : "inactive"}"
        "2")
      (button
        :class "${active_ws == 3 ? "active" : "inactive"}"
        "3")
      (button
        :class "${active_ws == 4 ? "active" : "inactive"}"
        "4")
      (button
        :class "${active_ws == 5 ? "active" : "inactive"}"
        "5")
    )

    (box :orientation "horizontal"
      (button
        :class "${active_ws == 6 ? "active" : "inactive"}"
        "6")
      (button
        :class "${active_ws == 7 ? "active" : "inactive"}"
        "7")
      (button
        :class "${active_ws == 8 ? "active" : "inactive"}"
        "8")
      (button
        :class "${active_ws == 9 ? "active" : "inactive"}"
        "9")
      (button
        :class "${active_ws == 10 ? "active" : "inactive"}"
        "10")
    )

    (box :orientation "horizontal"
      (button
        :class "${active_ws == 11 ? "active" : "inactive"}"
        "11")
      (button
        :class "${active_ws == 12 ? "active" : "inactive"}"
        "12")
      (button
        :class "${active_ws == 13 ? "active" : "inactive"}"
        "13")
      (button
        :class "${active_ws == 14 ? "active" : "inactive"}"
        "14")
      (button
        :class "${active_ws == 15 ? "active" : "inactive"}"
        "15")
    )
  )
)