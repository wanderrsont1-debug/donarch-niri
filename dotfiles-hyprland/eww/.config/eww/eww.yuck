      (button :onclick "~/.config/hypr/scripts/hl-popin.sh && hyprctl eval 'hl.dispatch(hl.dsp.focus({ workspace = \"5\" })) hl.dispatch(hl.dsp.submap(\"reset\"))' && eww close overview"
        (box :orientation "vertical"
          (label :text "5")
          (label :text ws5icons :class "icons")
        )
      )
    )

    (box :orientation "horizontal"
      (button :onclick "~/.config/hypr/scripts/hl-popin.sh && hyprctl eval 'hl.dispatch(hl.dsp.focus({ workspace = \"6\" })) hl.dispatch(hl.dsp.submap(\"reset\"))' && eww close overview"
        (box :orientation "vertical"
