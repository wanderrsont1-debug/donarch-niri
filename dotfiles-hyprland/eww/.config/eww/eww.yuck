      (button :onclick "~/.config/hypr/scripts/hl-popin.sh && hyprctl eval 'hl.dispatch(hl.dsp.focus({ workspace = \"4\" })) hl.dispatch(hl.dsp.submap(\"reset\"))' && eww close overview"
        (box :orientation "vertical"
