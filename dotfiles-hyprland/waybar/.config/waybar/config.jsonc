{
  "layer": "top",
  "output": "DP-3",
  "position": "top",

  "modules-left": ["custom/wallpaper", "hyprland/window"],
  "modules-center": ["custom/day", "clock", "custom/date"],
  "modules-right": ["custom/colorpicker", "custom/tuipom","network#vpn", "bluetooth", "pulseaudio", "custom/power"],  

  "clock": {
    "tooltip": false,
    "format": "{:%I:%M:%S}",
    "interval": 1,
    "on-click": "gnome-clocks"
  },
  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "",
    "format-icons": {
      "default": ["", "", " "]
    },
    "on-click": "pavucontrol"
  },
  "bluetooth": {
    "format-on": "󰂯",
    "format-off": "󰂲",
    "format-disabled": "",
    "format-connected": "󰂱",
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_battery_percentage}%",
    "on-click": "rfkill toggle bluetooth",
    "on-click-right": "blueman-manager"
},
  "custom/day": {
    "exec": "date +'%a'",
    "interval": 60,
    "on-click": "gtk-launch WebApp-Reminders0631",
    "tooltip-format": "Today's To Do"
  },
  "custom/date": {
    "exec": "date +'%-m/%-d'",
    "interval": 60,
    "on-click": "hyprctl eval 'hl.dispatch(hl.dsp.workspace.toggle_special(\"calendar\"))'",
    "on-click-right": "hyprctl eval 'hl.exec_cmd(\"gnome-calendar\")'", // Back up to restart the calendar if needed
    "tooltip-format": "Click to open calendar"
  },
  "custom/wallpaper": {
    "exec": "~/.config/hypr/scripts/wallpaper_icon.sh",
    "on-click": "~/.config/hypr/scripts/toggle_wallpaper.sh",
  "interval": 1
  },
  "custom/power": {
	"format" : "⏻",
	"tooltip-format": "Power Menu",
  "on-click": "eww active-windows | grep powermenu  && eww close powermenu  || eww open powermenu"
  },
  "custom/tuipom": {
	"format" : "󰥕",
	"tooltip-format": "Pomodoro Timer",
  "on-click": "hyprctl eval 'hl.dispatch(hl.dsp.workspace.toggle_special(\"pomodoro\"))'",
  "on-click-right": "ghostty +new-window --title=pomodoro -e ~/.cargo/bin/timr-tui -m pomodoro"
  },
  "custom/colorpicker": {
	"format" : "󰉦",
	"tooltip-format": "Pick Color",
  "on-click": "hyprpicker -a -n"
  },
  "network#vpn": {
    "interface": "wg0-mullvad",
    "format": "",
    "format-disconnected": "",
    "tooltip": false,
    "on-click": "mullvad status | grep Connected && mullvad disconnect || mullvad connect",
    "on-click-right": "/opt/Mullvad\\ VPN/mullvad-vpn & disown"
  }
} 